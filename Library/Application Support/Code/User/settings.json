{
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "explorer.confirmPasteNative": false,
  "liveServer.settings.donotShowInfoMsg": true,
  "editor.linkedEditing": true,
  "r.rterm.mac": "/usr/local/bin/R",
  "color-highlight.markerType": "dot-before",
  "editor.wordWrap": "on",
  "emmet.triggerExpansionOnTab": true,
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "[sql]": {
    "editor.defaultFormatter": "mtxr.sqltools",
  },
  "files.exclude": {
    "": true,
    "**/.git": false,
  },
  "python.languageServer": "Pylance",
  "redhat.telemetry.enabled": true,
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
  },
  "editor.cursorStyle": "block",
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "workbench.startupEditor": "none",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "github.copilot.editor.enableAutoCompletions": false,
  "print.folder.fileNames": true,
  "print.folder.include": [],
  "print.folder.exclude": [
    "{bin,obj,out}",
    "node_modules",
    "data",
    "**/*.{bin,exe,dll,hex,pdb,pdf,pfx,png,jpg,gif,bmp,suo,design}",
  ],
  "print.folder.maxLines": 1200,
  "print.folder.maxFiles": 30,
  "print.folder.includeFileList": false,
  "git.confirmSync": false,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "workbench.preferredHighContrastColorTheme": "Dark Modern",
  "window.autoDetectHighContrast": false,
  "workbench.preferredHighContrastLightColorTheme": "Light Modern",
  "workbench.colorCustomizations": {},
  "terminal.external.osxExec": "code",
  "rust-analyzer.completion.callable.snippets": "none",
  "rust-analyzer.inlayHints.parameterHints.enable": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "git.enableSmartCommit": true,
  "python.analysis.typeCheckingMode": "basic",
  "editor.mouseWheelZoom": true,
  "window.zoomPerWindow": false,
  "terminal.integrated.mouseWheelZoom": true,
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma",
  },
  "editor.formatOnSave": true,
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "terminal.integrated.fontFamily": "MesloLGS Nerd Font Mono",
  "javascript.preferences.organizeImports": {
    "caseSensitivity": "auto",
  },
  "tailwindCSS.experimental.configFile": null,
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript",
  },
  "javascript.format.semicolons": "insert",
  "workbench.iconTheme": "material-icon-theme",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "window.nativeTabs": true,
  "terminal.integrated.macOptionIsMeta": true,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "claudeCode.preferredLocation": "panel",
  "docker.extension.enableComposeLanguageServer": false,
  "editor.rulers": [80],
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": true,
  "editor.renderWhitespace": "none",
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
  },
  "workbench.colorTheme": "One Dark Pro",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "remote.autoForwardPortsSource": "hybrid",
  "chat.viewSessions.orientation": "stacked",
  "explorer.compactFolders": false,
  "editor.trimWhitespaceOnDelete": true,
  "files.trimTrailingWhitespace": true,
  "window.zoomLevel": 1,
  "files.associations": {
    "*.dbclient-js": "javascript",
    "*.rmd": "markdown",
  },
}
